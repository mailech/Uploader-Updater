# The database the tool reads KVKs from and writes imported data into.
# Use a STANDARD postgres URL (postgresql://user:pass@host/db?sslmode=require).
# Point this at your TEST/sandbox DB while trying things out, or your live DB to publish.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Optional: only needed if DATABASE_URL is a Prisma Accelerate (prisma+...) URL.
# DIRECT_URL is used by `prisma generate` / CLI. If DATABASE_URL is already a plain
# postgres URL you can leave this unset.
# DIRECT_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Port the tool listens on (default 5050). Hosts like Render set PORT automatically.
IMPORT_TOOL_PORT=5050
